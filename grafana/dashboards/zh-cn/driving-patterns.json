          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('month', d.start_date) AS time,\n  ROUND((\n    COALESCE(SUM((d.start_ideal_range_km - d.end_ideal_range_km) * c.efficiency), 0)\n    / NULLIF(SUM(d.distance), 0)\n    * 1000\n  )::numeric, 1) AS \"月均能耗\"\nFROM drives d\nJOIN cars c ON c.id = d.car_id\nWHERE d.car_id = $car_id\n  AND $__timeFilter(d.start_date)\n  AND d.distance > 0\n  AND d.start_ideal_range_km > d.end_ideal_range_km\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "按月能耗趋势 (Wh/km)",
      "type": "timeseries",
      "transformations": [
        {
          "id": "regression",
          "options": {
            "modelType": "linear",
            "xFieldName": "Time",
            "yFieldName": "月均能耗",
            "predictionCount": 100
          }
        }
      ]
